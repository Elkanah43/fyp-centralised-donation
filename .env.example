# Copy to .env (or set as real environment variables) for production.

# REQUIRED in production. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set to 0 in production. Defaults to 1 (development).
DJANGO_DEBUG=0

# Comma-separated hostnames the site is served from.
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Comma-separated origins for CSRF (scheme required).
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Demo mode seeds sample data and exposes the public "Reset Data" endpoint.
# Set to 0 for a real deployment.
DEMO_MODE=1

# Set to 0 if TLS is terminated elsewhere without X-Forwarded-Proto.
DJANGO_SECURE_SSL_REDIRECT=1
